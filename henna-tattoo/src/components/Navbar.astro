---
import Logo from './Logo.astro';
import { site } from '../lib/site';

const links = [
  { href: '/#categories', label: 'Categories' },
  { href: '/#gallery', label: 'Gallery' },
  { href: '/#events', label: 'Events' },
  { href: '/#about', label: 'About' },
  { href: '/#hours', label: 'Hours' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-40 border-b border-henna-100/60 bg-cream/80 backdrop-blur">
  <div class="container-prose flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-3" aria-label={site.name}>
      <Logo size={40} />
      <span class="flex flex-col leading-tight">
        <span class="font-display text-lg text-henna-700">{site.name}</span>
        <span class="text-[10px] uppercase tracking-[0.25em] text-henna-500">{site.tagline}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-sm font-medium text-ink/70 transition hover:text-henna-600"
          >
            {l.label}
          </a>
        ))
      }
      <a href="/contact" class="btn-primary !py-2 !px-4">Book now</a>
    </nav>

    <button
      type="button"
      id="navbar-toggle"
      class="inline-flex h-10 w-10 items-center justify-center rounded-md text-henna-700 md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="navbar-icon-open"
        class="block"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg
        id="navbar-icon-close"
        class="hidden"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-henna-100 bg-cream md:hidden">
    <div class="container-prose flex flex-col gap-1 py-3">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-md px-3 py-2 text-sm font-medium text-ink/80 hover:bg-henna-50"
          >
            {l.label}
          </a>
        ))
      }
      <a href="/contact" class="btn-primary mt-2 self-start">Book now</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('navbar-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('navbar-icon-open');
  const iconClose = document.getElementById('navbar-icon-close');

  toggle?.addEventListener('click', () => {
    if (!menu || !iconOpen || !iconClose) return;
    const nowOpen = menu.classList.toggle('hidden') === false;
    iconOpen.classList.toggle('hidden', nowOpen);
    iconOpen.classList.toggle('block', !nowOpen);
    iconClose.classList.toggle('hidden', !nowOpen);
    iconClose.classList.toggle('block', nowOpen);
    toggle.setAttribute('aria-expanded', String(nowOpen));
  });
</script>
