---
import type { Category } from '../lib/categories';

interface Props {
  category: Category;
}

const { category } = Astro.props;
---

<a
  href={`/categories/${category.slug}`}
  class="group relative flex h-full flex-col overflow-hidden rounded-3xl border border-henna-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
>
  <div class={`relative aspect-[4/3] w-full overflow-hidden bg-gradient-to-br ${category.accent}`}>
    {
      category.image ? (
        <>
          <img
            src={category.image}
            alt={category.title}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/10 to-transparent"></div>
        </>
      ) : (
        <>
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.25),transparent_60%)]"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/5 to-transparent"></div>
        </>
      )
    }

    <div class="absolute bottom-4 left-5 right-5 flex items-center justify-between">
      <span
        class="rounded-full bg-white/85 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-henna-700 shadow-sm backdrop-blur"
      >
        From {category.startingAt}
      </span>
    </div>
  </div>

  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-2xl font-display text-henna-700">{category.title}</h3>
    <p class="mt-1 text-sm italic text-henna-500">{category.tagline}</p>
    <p class="mt-4 text-sm text-ink/70">{category.description}</p>

    <div class="mt-6 flex items-center justify-between text-sm font-semibold text-henna-600">
      <span>View designs &amp; pricing</span>
      <span class="transition group-hover:translate-x-1" aria-hidden="true">→</span>
    </div>
  </div>
</a>
