---
import { site } from '../lib/site';
---

<section class="relative overflow-hidden bg-paisley">
  <div class="container-prose grid gap-10 pb-20 pt-16 md:grid-cols-2 md:gap-16 md:pt-24">
    <div class="flex flex-col justify-center">
      <span class="eyebrow">{site.tagline}</span>
      <h1 class="mt-4 text-5xl font-display text-henna-700 sm:text-6xl lg:text-7xl">
        Henna tattoos,<br />
        <span class="italic text-henna-500">made for you.</span>
      </h1>
      <p class="mt-6 max-w-lg text-lg text-ink/70">
        Jagua, brown, white, glitter and colourful henna — all designed and
        drawn by hand in {site.location.shortLabel}. Perfect for weddings,
        festivals, events and everything in between.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="btn-primary">Book a session</a>
        <a href="/#categories" class="btn-secondary">Explore styles</a>
      </div>

      <dl class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm md:mt-12 md:grid md:max-w-md md:grid-cols-3 md:gap-6">
        <div class="flex items-baseline gap-2 md:block">
          <dt class="font-display text-2xl text-henna-600 md:text-3xl">5</dt>
          <dd class="text-ink/60">Henna styles</dd>
        </div>
        <div class="flex items-baseline gap-2 md:block">
          <dt class="font-display text-2xl text-henna-600 md:text-3xl">100%</dt>
          <dd class="text-ink/60">Skin-safe paste</dd>
        </div>
        <div class="flex items-baseline gap-2 md:block">
          <dt class="font-display text-2xl text-henna-600 md:text-3xl">1:1</dt>
          <dd class="text-ink/60">Custom designs</dd>
        </div>
      </dl>
    </div>

    <div class="relative flex items-center justify-center">
      <div class="absolute inset-0 -z-10 bg-gradient-to-br from-henna-100 via-transparent to-henna-200 blur-3xl"></div>

      <!-- mobile: compact 2×2 grid with portrait tiles -->
      <div class="grid w-full grid-cols-2 gap-3 md:hidden">
        <a href="/categories/brown-henna" class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <img src="/images/brown.jpg" alt="Brown henna" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">Brown henna</span>
        </a>
        <a href="/categories/jagua-henna" class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <img src="/images/jagua.jpg" alt="Jagua henna" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">Jagua</span>
        </a>
        <a href="/categories/white-henna" class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <img src="/images/white.jpg" alt="White henna" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">White lace</span>
        </a>
        <a href="/categories/colorful-henna" class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <img src="/images/pink.jpg" alt="Colourful henna" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">Glitter & colour</span>
        </a>
      </div>

      <!-- desktop: original staggered tall tiles -->
      <div class="relative hidden w-full max-w-md grid-cols-2 gap-4 md:grid">
        <a href="/categories/brown-henna" class="hero-tile group aspect-[3/4] overflow-hidden rounded-3xl bg-gradient-to-br from-henna-400 to-henna-700 shadow-xl">
          <img src="/images/brown.jpg" alt="Brown henna design" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">Brown henna</span>
        </a>
        <a href="/categories/jagua-henna" class="hero-tile group aspect-[3/4] translate-y-8 overflow-hidden rounded-3xl bg-gradient-to-br from-slate-800 to-slate-950 shadow-xl">
          <img src="/images/jagua.jpg" alt="Jagua henna design" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">Jagua</span>
        </a>
        <a href="/categories/white-henna" class="hero-tile group aspect-[3/4] overflow-hidden rounded-3xl bg-gradient-to-br from-stone-100 to-stone-300 shadow-xl">
          <img src="/images/white.jpg" alt="White henna design" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">White lace</span>
        </a>
        <a href="/categories/colorful-henna" class="hero-tile group aspect-[3/4] translate-y-8 overflow-hidden rounded-3xl bg-gradient-to-br from-rose-400 via-fuchsia-500 to-amber-400 shadow-xl">
          <img src="/images/pink.jpg" alt="Colourful henna design" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">Glitter & colour</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-tile {
    position: relative;
    display: block;
    transition:
      transform 400ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-tile:hover {
    box-shadow: 0 20px 50px -12px rgba(139, 69, 19, 0.35);
  }
  /* Make hover lift play nicely with the staggered translate-y-8 tiles */
  .hero-tile:not(.translate-y-8):hover { transform: translateY(-4px); }
  .hero-tile.translate-y-8:hover { transform: translateY(calc(2rem - 4px)); }

  .hero-tile-label {
    position: absolute;
    left: 1.25rem;
    bottom: 1.25rem;
  }
</style>
