---
import { getSite } from '../lib/site';
import { getLang, dict, fmt, localizePath } from '../lib/i18n';
import Picture from './Picture.astro';

const lang = getLang(Astro);
const site = getSite(lang);
const t = dict.hero;

const tileImg = 'absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105';
// Mobile: each tile is ~50vw of the gutter-trimmed container, so 480w fits
// retina perfectly (~412px viewport × DPR 2.6 ≈ 480px). Desktop: 14rem = 224px,
// so 480w covers DPR 2 retina too. The browser auto-picks 320/480/640 based
// on DPR from the srcset emitted by Picture.astro.
const tileSizes = '(min-width: 768px) 14rem, calc(50vw - 1rem)';
---

<section class="relative overflow-hidden bg-paisley">
  <div class="container-prose grid gap-10 pb-20 pt-16 md:grid-cols-2 md:gap-16 md:pt-24">
    <div class="flex flex-col justify-center">
      <span class="eyebrow">{site.tagline}</span>
      <h1 class="mt-4 text-5xl font-display text-henna-700 sm:text-6xl lg:text-7xl">
        {t.headlineLine1[lang]}<br />
        <span class="italic text-henna-500">{t.headlineLine2[lang]}</span>
      </h1>
      <p class="mt-6 max-w-lg text-lg text-ink/70">
        {fmt(t.intro[lang], { place: site.location.shortLabel })}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={localizePath('/contact', lang)} class="btn-primary">{t.bookSession[lang]}</a>
        <a href={localizePath('/#categories', lang)} class="btn-secondary">{t.exploreStyles[lang]}</a>
      </div>

      <dl class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm md:mt-12 md:grid md:max-w-md md:grid-cols-3 md:gap-6">
        <div class="flex items-baseline gap-2 md:block">
          <dt class="font-display text-2xl text-henna-600 md:text-3xl">5</dt>
          <dd class="text-ink/70">{t.statStyles[lang]}</dd>
        </div>
        <div class="flex items-baseline gap-2 md:block">
          <dt class="font-display text-2xl text-henna-600 md:text-3xl">100%</dt>
          <dd class="text-ink/70">{t.statSafe[lang]}</dd>
        </div>
        <div class="flex items-baseline gap-2 md:block">
          <dt class="font-display text-2xl text-henna-600 md:text-3xl">1:1</dt>
          <dd class="text-ink/70">{t.statCustom[lang]}</dd>
        </div>
      </dl>
    </div>

    <div class="relative flex items-center justify-center">
      <div class="absolute inset-0 -z-10 bg-gradient-to-br from-henna-100 via-transparent to-henna-200 blur-3xl"></div>

      <div class="grid w-full grid-cols-2 gap-3 md:hidden">
        <a href={localizePath('/categories/brown-henna', lang)} aria-label={t.tileBrown[lang]} class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <Picture src="/images/brown.jpg" alt="" sizes={tileSizes} loading="eager" fetchpriority="high" width={787} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">{t.tileBrown[lang]}</span>
        </a>
        <a href={localizePath('/categories/jagua-henna', lang)} aria-label={t.tileJagua[lang]} class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <Picture src="/images/jagua_category.jpg" alt="" sizes={tileSizes} loading="eager" fetchpriority="high" width={1133} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">{t.tileJagua[lang]}</span>
        </a>
        <a href={localizePath('/categories/white-henna', lang)} aria-label={t.tileWhite[lang]} class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <Picture src="/images/white.jpg" alt="" sizes={tileSizes} loading="eager" width={1050} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">{t.tileWhite[lang]}</span>
        </a>
        <a href={localizePath('/categories/colorful-henna', lang)} aria-label={t.tileColor[lang]} class="hero-tile group aspect-[4/5] overflow-hidden rounded-2xl shadow-lg">
          <Picture src="/images/pink.jpg" alt="" sizes={tileSizes} loading="eager" width={886} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label text-sm font-semibold text-cream drop-shadow">{t.tileColor[lang]}</span>
        </a>
      </div>

      <div class="relative hidden w-full max-w-md grid-cols-2 gap-4 md:grid">
        <a href={localizePath('/categories/brown-henna', lang)} aria-label={t.tileBrown[lang]} class="hero-tile group aspect-[3/4] overflow-hidden rounded-3xl bg-gradient-to-br from-henna-400 to-henna-700 shadow-xl">
          <Picture src="/images/brown.jpg" alt="" sizes={tileSizes} loading="eager" fetchpriority="high" width={787} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">{t.tileBrown[lang]}</span>
        </a>
        <a href={localizePath('/categories/jagua-henna', lang)} aria-label={t.tileJagua[lang]} class="hero-tile group aspect-[3/4] translate-y-8 overflow-hidden rounded-3xl bg-gradient-to-br from-slate-800 to-slate-950 shadow-xl">
          <Picture src="/images/jagua_category.jpg" alt="" sizes={tileSizes} loading="eager" fetchpriority="high" width={1133} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">{t.tileJagua[lang]}</span>
        </a>
        <a href={localizePath('/categories/white-henna', lang)} aria-label={t.tileWhite[lang]} class="hero-tile group aspect-[3/4] overflow-hidden rounded-3xl bg-gradient-to-br from-stone-100 to-stone-300 shadow-xl">
          <Picture src="/images/white.jpg" alt="" sizes={tileSizes} loading="eager" width={1050} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">{t.tileWhite[lang]}</span>
        </a>
        <a href={localizePath('/categories/colorful-henna', lang)} aria-label={t.tileColor[lang]} class="hero-tile group aspect-[3/4] translate-y-8 overflow-hidden rounded-3xl bg-gradient-to-br from-rose-400 via-fuchsia-500 to-amber-400 shadow-xl">
          <Picture src="/images/pink.jpg" alt="" sizes={tileSizes} loading="eager" width={886} height={1400} class={tileImg} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent"></div>
          <span class="hero-tile-label font-display text-xl text-cream drop-shadow-lg">{t.tileColor[lang]}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-tile {
    position: relative;
    display: block;
    transition:
      transform 400ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-tile:hover {
    box-shadow: 0 20px 50px -12px rgba(139, 69, 19, 0.35);
  }
  .hero-tile:not(.translate-y-8):hover { transform: translateY(-4px); }
  .hero-tile.translate-y-8:hover { transform: translateY(calc(2rem - 4px)); }

  .hero-tile-label {
    position: absolute;
    left: 1.25rem;
    bottom: 1.25rem;
  }
</style>
