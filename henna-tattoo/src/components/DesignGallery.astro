---
import { getLang, dict } from '../lib/i18n';
import Picture from './Picture.astro';

interface Props {
  images: string[];
  accent: string;
  title: string;
}

const { images, accent, title } = Astro.props;
const lang = getLang(Astro);
const t = dict.gallery;
---

{
  images.length === 0 ? (
    <div class="rounded-2xl border border-dashed border-henna-200 bg-henna-50/40 p-10 text-center">
      <p class="font-display text-xl text-henna-700">{t.soonTitle[lang]}</p>
    </div>
  ) : (
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
      {images.map((src, i) => (
        <div class={`relative aspect-square overflow-hidden rounded-2xl bg-gradient-to-br ${accent}`}>
          <Picture
            src={src}
            alt={`${title} ${t.altSuffix[lang]} ${i + 1}`}
            sizes="(min-width: 640px) 33vw, 50vw"
            loading="lazy"
            class="h-full w-full object-cover transition duration-500 hover:scale-105"
          />
        </div>
      ))}
    </div>
  )
}
