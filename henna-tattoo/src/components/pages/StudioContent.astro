---
import Layout from '../../layouts/Layout.astro';
import { getSite } from '../../lib/site';
import { getLang, dict, pick, localizePath } from '../../lib/i18n';

const lang = getLang(Astro);
const site = getSite(lang);
const t = dict.studio;
const contactHref = localizePath('/contact', lang);
const waHref = `https://wa.me/${site.contact.whatsappNumber}`;
---

<Layout
  title={`${pick(t.metaTitlePrefix, lang)} — ${site.name}`}
  description={pick(t.metaDescription, lang)}
>
  <section class="py-12 sm:py-16">
    <div class="container-prose">
      <span class="eyebrow">{pick(t.eyebrow, lang)}</span>
      <h1 class="mt-3 text-4xl font-display text-henna-700 sm:text-5xl">{pick(t.title, lang)}</h1>
      <p class="mt-4 max-w-2xl text-ink/70">{pick(t.intro, lang)}</p>

      <div id="studio-root" class="mt-8 min-h-[40vh]"></div>

      <noscript>
        <div class="mt-6 rounded-2xl border border-henna-200 bg-white p-6">
          <h2 class="font-display text-2xl text-henna-700">{pick(t.noJsTitle, lang)}</h2>
          <p class="mt-2 text-ink/70">{pick(t.noJsBody, lang)}</p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a href={contactHref} class="btn-primary">{pick(dict.nav.bookNow, lang)}</a>
            <a href={waHref} class="btn-secondary" target="_blank" rel="noreferrer">{pick(dict.studio.actions.sendWa, lang)}</a>
          </div>
        </div>
      </noscript>
    </div>
  </section>
</Layout>

<script>
  import { mountStudio } from '../../components/studio/index';
  import { getLangFromPath } from '../../lib/i18n';

  const root = document.getElementById('studio-root');
  if (root) {
    const lang = getLangFromPath(window.location.pathname);
    mountStudio(root, lang);
  }
</script>

<style>
  /* Konva mounts two stacked <canvas> tags inside .studio-canvas-mount.
     Konva drives their pixel sizes; the mount itself stays full-width
     of its parent so the resize() function can read clientWidth. */
  :global(.studio-canvas-mount) {
    width: 100%;
    line-height: 0;
    user-select: none;
    touch-action: none;
  }
  :global(.studio-canvas-mount canvas) {
    display: block;
    max-width: 100%;
    height: auto;
  }
</style>
