---
import Logo from './Logo.astro';
import { site } from '../lib/site';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-henna-100 bg-henna-50/50">
  <div class="container-prose grid gap-10 py-12 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-3">
        <Logo size={40} />
        <span class="flex flex-col leading-tight">
          <span class="font-display text-lg text-henna-700">{site.name}</span>
          <span class="text-[10px] uppercase tracking-[0.25em] text-henna-500">{site.tagline}</span>
        </span>
      </div>
      <p class="mt-3 max-w-sm text-sm text-ink/70">
        Handcrafted henna tattoos for weddings, festivals, events and everyday
        magic. Based in {site.location.shortLabel}.
      </p>
    </div>

    <div>
      <h4 class="text-sm font-semibold uppercase tracking-widest text-henna-600">Explore</h4>
      <ul class="mt-4 space-y-2 text-sm text-ink/70">
        <li><a href="/#categories" class="hover:text-henna-700">Categories</a></li>
        <li><a href="/#about" class="hover:text-henna-700">About</a></li>
        <li><a href="/#gallery" class="hover:text-henna-700">Gallery</a></li>
        <li><a href="/contact" class="hover:text-henna-700">Book a session</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold uppercase tracking-widest text-henna-600">Get in touch</h4>
      <ul class="mt-4 space-y-2 text-sm text-ink/70">
        <li>
          <a href={`mailto:${site.contact.email}`} class="hover:text-henna-700">
            {site.contact.email}
          </a>
        </li>
        <li>
          <a href={`tel:${site.contact.phoneIntl}`} class="hover:text-henna-700">
            {site.contact.phone}
          </a>
        </li>
        <li>
          <a
            href={site.social.instagramUrl}
            target="_blank"
            rel="noreferrer"
            class="hover:text-henna-700"
          >
            Instagram · @{site.social.instagramHandle}
          </a>
        </li>
        <li>
          <a
            href={site.social.tiktokUrl}
            target="_blank"
            rel="noreferrer"
            class="hover:text-henna-700"
          >
            TikTok · @{site.social.tiktokHandle}
          </a>
        </li>
        <li>
          <a
            href={site.location.mapsUrl}
            target="_blank"
            rel="noreferrer"
            class="hover:text-henna-700"
          >
            {site.location.label}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-henna-100">
    <div class="container-prose flex flex-col items-center justify-between gap-2 py-4 text-xs text-ink/50 sm:flex-row">
      <span>© {year} {site.name}. All rights reserved.</span>
      <span>Artist: {site.artist}</span>
    </div>
  </div>
</footer>
