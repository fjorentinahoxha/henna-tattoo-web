---
import Logo from './Logo.astro';
import { getSite } from '../lib/site';
import { getLang, dict, fmt, localizePath } from '../lib/i18n';

const lang = getLang(Astro);
const site = getSite(lang);
const t = dict.footer;

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-henna-100 bg-henna-50/50">
  <div class="container-prose grid gap-10 py-12 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-3">
        <Logo size={40} />
        <span class="font-display text-lg text-henna-700 leading-tight">{site.name}</span>
      </div>
      <p class="mt-3 max-w-sm text-sm text-ink/70">
        {fmt(t.blurb[lang], { place: site.location.shortLabel })}
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-widest text-henna-600">{t.explore[lang]}</h2>
      <ul class="mt-4 space-y-2 text-sm text-ink/70">
        <li><a href={localizePath('/#categories', lang)} class="hover:text-henna-700">{t.categories[lang]}</a></li>
        <li><a href={localizePath('/#about',      lang)} class="hover:text-henna-700">{t.about[lang]}</a></li>
        <li><a href={localizePath('/#gallery',    lang)} class="hover:text-henna-700">{t.gallery[lang]}</a></li>
        <li><a href={localizePath('/contact',     lang)} class="hover:text-henna-700">{t.bookSession[lang]}</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-widest text-henna-600">{t.getInTouch[lang]}</h2>
      <ul class="mt-4 space-y-2 text-sm text-ink/70">
        <li>
          <a href={`mailto:${site.contact.email}`} class="hover:text-henna-700">
            {site.contact.email}
          </a>
        </li>
        <li>
          <a href={`tel:${site.contact.phoneIntl}`} class="hover:text-henna-700">
            {site.contact.phone}
          </a>
        </li>
        <li>
          <a
            href={site.social.instagramUrl}
            target="_blank"
            rel="noreferrer"
            class="hover:text-henna-700"
          >
            Instagram · @{site.social.instagramHandle}
          </a>
        </li>
        <li>
          <a
            href={site.social.tiktokUrl}
            target="_blank"
            rel="noreferrer"
            class="hover:text-henna-700"
          >
            TikTok · @{site.social.tiktokHandle}
          </a>
        </li>
        <li>
          <a
            href={site.location.mapsUrl}
            target="_blank"
            rel="noreferrer"
            class="hover:text-henna-700"
          >
            {site.location.label}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-henna-100">
    <div class="container-prose flex flex-col items-center justify-between gap-2 py-4 text-xs text-ink/70 sm:flex-row">
      <span>© {year} {site.name}. {t.rights[lang]}</span>
      <span>{t.artist[lang]} {site.artist}</span>
    </div>
  </div>
</footer>
