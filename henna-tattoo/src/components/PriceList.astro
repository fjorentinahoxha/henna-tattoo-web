---
import type { PriceItem } from '../lib/categories';

interface Props {
  items: PriceItem[];
}

const { items } = Astro.props;
---

<ul class="divide-y divide-henna-100 rounded-2xl border border-henna-100 bg-white">
  {
    items.map((item) => (
      <li class="flex items-start justify-between gap-6 p-5">
        <div>
          <p class="font-medium text-ink">{item.name}</p>
          {item.description && (
            <p class="mt-0.5 text-sm text-ink/70">{item.description}</p>
          )}
        </div>
        <span class="whitespace-nowrap font-display text-lg text-henna-600">
          {item.price}
        </span>
      </li>
    ))
  }
</ul>
