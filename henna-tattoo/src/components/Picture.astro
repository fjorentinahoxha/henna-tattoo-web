---
/**
 * <Picture> — responsive, modern-format image for /public/images assets.
 *
 * Pairs with scripts/optimize-images.mjs which generates, for every source
 * photo under _originals/, sibling files at widths 640 / 1024 / 1600 in
 * AVIF + WebP + JPG/PNG — but only widths <= the source width. Smaller
 * source photos therefore have fewer variants.
 *
 * The component reads the optimizer's manifest at build time so that the
 * srcset only references files that actually exist on the CDN. Without
 * this guard the browser would request, e.g., `brown-1024.avif` for a
 * 787-px source, hit a 404, and render a broken image.
 *
 *   <Picture src="/images/jagua_category.jpg" alt="Jagua" sizes="33vw" />
 */

import manifest from '../../scripts/.image-manifest.json';

interface Props {
  src: string;
  alt: string;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  width?: number;
  height?: number;
}

type ManifestEntry =
  | { kind: 'image'; widths: number[]; fallback: string; extFallback: string }
  | { kind: 'copy' };

const {
  src,
  alt,
  sizes = '100vw',
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  class: className,
  width,
  height,
} = Astro.props as Props;

const rel = src.startsWith('/images/') ? src.slice('/images/'.length) : '';
const entry = (manifest as Record<string, ManifestEntry>)[rel];

const dot   = src.lastIndexOf('.');
const slash = src.lastIndexOf('/');
const ext   = dot > slash ? src.slice(dot) : '';
const stem  = dot > slash ? src.slice(slash + 1, dot) : src.slice(slash + 1);
const dir   = src.slice(0, slash);

const availableWidths: number[] =
  entry && entry.kind === 'image' ? entry.widths : [];

const variant = (w: number, e: string) => `${dir}/${stem}-${w}${e}`;
const buildSrcset = (e: string) =>
  availableWidths.map((w) => `${variant(w, e)} ${w}w`).join(', ');

const showResponsive = availableWidths.length > 0;
---

{showResponsive ? (
  <picture style="display:contents">
    <source type="image/avif" srcset={buildSrcset('.avif')} sizes={sizes} />
    <source type="image/webp" srcset={buildSrcset('.webp')} sizes={sizes} />
    <img
      src={src}
      srcset={buildSrcset(ext)}
      sizes={sizes}
      alt={alt}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      width={width}
      height={height}
      class={className}
    />
  </picture>
) : (
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    width={width}
    height={height}
    class={className}
  />
)}
