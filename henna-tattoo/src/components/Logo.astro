---
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className = '' } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center justify-center overflow-hidden rounded-full bg-cream ring-1 ring-henna-200',
    className,
  ]}
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
>
  <img
    src="/images/logo.svg"
    alt=""
    width={size}
    height={size}
    class="h-full w-full object-contain"
    loading="eager"
    decoding="async"
  />
</span>
