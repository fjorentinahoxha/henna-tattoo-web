---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BackgroundMehndi from '../components/BackgroundMehndi.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { categories } from '../lib/categories';
import { events } from '../lib/events';
import { site } from '../lib/site';
---

<Layout>
  <BackgroundMehndi />
  <Hero />

  <section id="categories" class="py-10 sm:py-12">
    <div class="container-prose">
      <div class="max-w-2xl">
        <span class="eyebrow">Styles</span>
        <h2 class="section-title mt-3">Five ways to wear your story</h2>
        <p class="mt-4 text-lg text-ink/70">
          From traditional bridal mehndi to festival-ready glitter and colour,
          every category is a different mood. Tap one to see full pricing and
          designs.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((category) => <CategoryCard category={category} />)}
      </div>
    </div>
  </section>


  <section id="gallery" class="py-10 sm:py-12">
    <div class="container-prose">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <span class="eyebrow">Featured work</span>
          <h2 class="section-title mt-3">A glimpse at the portfolio</h2>
        </div>
        <a href="/contact" class="btn-secondary">Request a design</a>
      </div>

      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {
          [
            { src: '/images/natural/IMG_2995.jpg',   alt: 'Brown henna design' },
            { src: '/images/jagua/IMG_2975.jpg',     alt: 'Jagua henna design' },
            { src: '/images/white/IMG_0604.jpg',     alt: 'White henna design' },
            { src: '/images/colorful/IMG_2983.jpg',   alt: 'Colorful henna design' },
            { src: '/images/natural/IMG_8514.jpeg',   alt: 'Brown henna design' },
            { src: '/images/glitter/IMG_0597.jpeg',   alt: 'Glitter henna design' },
            { src: '/images/jagua/IMG_7269.jpeg',     alt: 'Jagua henna design' },
            { src: '/images/colorful/IMG_5573.jpeg',  alt: 'Colorful henna design' },
          ].map(({ src, alt }) => (
            <div class="aspect-square overflow-hidden rounded-2xl shadow-sm bg-henna-100">
              <img
                src={src}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition duration-500 hover:scale-105"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="events" class="bg-henna-50/50 py-10 sm:py-12">
    <div class="container-prose">
      <div class="max-w-2xl">
        <span class="eyebrow">Events &amp; fairs</span>
        <h2 class="section-title mt-3">On stage, at the fair, at your party</h2>
        <p class="mt-4 text-lg text-ink/70">
          From birthday tables to national celebrations and major expos —
          a look at recent events where {site.name} has been featured.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          events.map(({ title, description, url }) => {
            const embedSrc = `${url.replace(/\/$/, '')}/embed`;
            return (
              <figure class="flex flex-col overflow-hidden rounded-3xl bg-white shadow-sm ring-1 ring-henna-100 transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="relative h-[390px] overflow-hidden rounded-t-3xl bg-henna-50">
                  <iframe
                    src={embedSrc}
                    class="absolute inset-x-0 -top-14 h-[620px] w-full border-0"
                    loading="lazy"
                    allow="encrypted-media; picture-in-picture; web-share"
                    allowtransparency="true"
                    scrolling="no"
                    title={title}
                  ></iframe>
                </div>
                <figcaption class="px-5 py-4">
                  <p class="font-display text-base text-henna-700">{title}</p>
                  {description && (
                    <p class="mt-1 text-sm text-ink/60">{description}</p>
                  )}
                </figcaption>
              </figure>
            );
          })
        }
      </div>

      <p class="mt-10 text-center text-sm text-ink/50">
        Planning an event? {' '}
        <a href="/contact" class="font-semibold text-henna-600 hover:text-henna-700">
          Book a henna station for your next fair or party →
        </a>
      </p>
    </div>
  </section>

  <section id="about" class="bg-henna-50/60 py-10 sm:py-12">
    <div class="container-prose grid gap-12 md:grid-cols-2 md:items-center">
      <div>
        <span class="eyebrow">About the studio</span>
        <h2 class="section-title mt-3">A modern take on an ancient art</h2>
        <p class="mt-4 text-ink/70">
          {site.name} is the work of {site.artist} — a certified henna artist
          based in {site.location.shortLabel}. Every design is drawn freehand,
          tailored to your body and the occasion, using natural, skin-safe paste.
        </p>
        <p class="mt-4 text-ink/70">
          From quiet wrist motifs to full bridal sets, festival glitter to neon
          event henna — you&apos;ll leave with artwork that feels like yours.
        </p>
        <p class="mt-4 text-sm text-henna-600">✦ {site.credentials}</p>
        <div class="mt-8 flex gap-3">
          <a href="/contact" class="btn-primary">Book a session</a>
          <a href="/#gallery" class="btn-secondary">See gallery</a>
        </div>
      </div>
      <figure>
        <div class="overflow-hidden rounded-3xl bg-cream shadow-lg ring-1 ring-henna-200/60">
          <img
            src="/images/certeficate.png"
            alt={`Certification of ${site.artist} as a professional henna artist`}
            class="h-auto w-full object-contain"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-center text-sm text-ink/50">
          Certified henna artist — Dubai Henna Master Course 2025.
        </figcaption>
      </figure>
    </div>
  </section>

  <section id="hours" class="py-10 sm:py-12">
    <div class="container-prose">
      <div class="text-center">
        <span class="eyebrow">Studio hours</span>
        <h2 class="section-title mt-3">When you can find me</h2>
        <p class="mx-auto mt-4 max-w-md text-ink/60">
          The studio is <strong class="text-henna-700">by appointment only</strong> —
          it is not open for walk-ins. Please book before coming so your session is confirmed and ready for you.
        </p>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-3 lg:grid-cols-6">
        {[
          { day: 'Monday',    hours: '18:00 – 22:00', bg: 'bg-amber-50',   border: 'border-amber-200',   text: 'text-amber-900' },
          { day: 'Tuesday',   hours: '18:00 – 22:00', bg: 'bg-rose-50',    border: 'border-rose-200',    text: 'text-rose-900'  },
          { day: 'Wednesday', hours: '18:00 – 22:00', bg: 'bg-violet-50',  border: 'border-violet-200',  text: 'text-violet-900'},
          { day: 'Thursday',  hours: '18:00 – 22:00', bg: 'bg-teal-50',    border: 'border-teal-200',    text: 'text-teal-900'  },
          { day: 'Friday',    hours: '18:00 – 22:00', bg: 'bg-sky-50',     border: 'border-sky-200',     text: 'text-sky-900'   },
          { day: 'Sat & Sun', hours: '24 hours',      bg: 'bg-henna-50',   border: 'border-henna-300',   text: 'text-henna-800' },
        ].map(({ day, hours, bg, border, text }) => (
          <div class={`flex flex-col items-center gap-3 rounded-2xl border ${bg} ${border} px-4 py-6 shadow-sm`}>
            <span class={`text-xs font-semibold uppercase tracking-widest ${text} opacity-70`}>{day}</span>
            <span class={`font-display text-lg font-bold ${text}`}>{hours}</span>
          </div>
        ))}
      </div>

      <p class="mt-8 flex items-center justify-center gap-2 text-sm text-ink/50">
        <span class="inline-block h-px w-8 bg-henna-300"></span>
        Book via the contact form or WhatsApp to reserve your time
        <span class="inline-block h-px w-8 bg-henna-300"></span>
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container-prose">
      <div class="relative overflow-hidden rounded-3xl bg-henna-600 px-8 py-14 text-cream sm:px-14">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(255,255,255,0.15),transparent_50%)]"></div>
        <div class="relative flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
          <div class="max-w-xl">
            <h2 class="text-3xl font-display sm:text-4xl">Ready for your design?</h2>
            <p class="mt-3 text-cream/80">
              Tell me the occasion, the style and how much space you want
              covered. I&apos;ll come back with a sketch and a quote.
            </p>
          </div>
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full bg-cream px-6 py-3 text-sm font-semibold uppercase tracking-widest text-henna-700 transition hover:bg-white"
          >
            Start a booking
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
