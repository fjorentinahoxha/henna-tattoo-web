---
import Layout from '../layouts/Layout.astro';
import { categories } from '../lib/categories';
import { site } from '../lib/site';
---

<Layout
  title={`Book a session — ${site.name}`}
  description="Request a henna tattoo booking in Tirana, Albania: weddings, festivals, parties and custom designs."
>
  <section class="py-16 sm:py-24">
    <div class="container-prose grid gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Get in touch</span>
        <h1 class="mt-3 text-4xl font-display text-henna-700 sm:text-5xl">
          Let&apos;s design something together.
        </h1>
        <p class="mt-4 max-w-md text-ink/70">
          Tell me about the occasion, the style you&apos;re drawn to and when
          you&apos;d like to book. I&apos;ll reply within 48 hours with a
          sketch direction and a quote.
        </p>

        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-henna-500">Email</p>
            <a
              href={`mailto:${site.contact.email}`}
              class="mt-1 block text-ink/80 hover:text-henna-700"
            >
              {site.contact.email}
            </a>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-henna-500">Phone</p>
            <a
              href={`tel:${site.contact.phoneIntl}`}
              class="mt-1 block text-ink/80 hover:text-henna-700"
            >
              {site.contact.phone}
            </a>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-henna-500">Instagram</p>
            <a
              href={site.social.instagramUrl}
              target="_blank"
              rel="noreferrer"
              class="mt-1 block text-ink/80 hover:text-henna-700"
            >
              @{site.social.instagramHandle}
            </a>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-henna-500">TikTok</p>
            <a
              href={site.social.tiktokUrl}
              target="_blank"
              rel="noreferrer"
              class="mt-1 block text-ink/80 hover:text-henna-700"
            >
              @{site.social.tiktokHandle}
            </a>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-henna-500">Studio</p>
            <a
              href={site.location.mapsUrl}
              target="_blank"
              rel="noreferrer"
              class="mt-1 block text-ink/80 hover:text-henna-700"
            >
              {site.location.label}
            </a>
          </div>
        </div>

        <div class="mt-8 rounded-2xl border border-henna-100 bg-white p-5 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-henna-500">Working hours</p>
          <ul class="mt-3 space-y-1 text-sm text-ink/70">
            <li class="flex justify-between"><span>Mon – Fri</span><span class="font-medium text-ink">18:00 – 22:00</span></li>
            <li class="flex justify-between"><span>Sat & Sun</span><span class="font-medium text-ink">24 hours</span></li>
          </ul>
          <p class="mt-3 text-xs text-henna-600">✦ By appointment only — the studio does not accept walk-ins. Please book before coming.</p>
        </div>

        <div class="mt-4 overflow-hidden rounded-2xl border border-henna-100 shadow-sm">
          <iframe
            src={site.location.embedUrl}
            title="Studio location on Google Maps"
            class="h-64 w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <form
        id="booking-form"
        class="rounded-3xl border border-henna-100 bg-white p-6 shadow-sm sm:p-8"
      >
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-henna-600">Name</span>
            <input
              name="name"
              required
              class="mt-1 w-full rounded-lg border border-henna-200 bg-cream px-3 py-2 text-sm focus:border-henna-500 focus:outline-none focus:ring-2 focus:ring-henna-200"
            />
          </label>
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-henna-600">Email</span>
            <input
              name="email"
              type="email"
              required
              class="mt-1 w-full rounded-lg border border-henna-200 bg-cream px-3 py-2 text-sm focus:border-henna-500 focus:outline-none focus:ring-2 focus:ring-henna-200"
            />
          </label>
        </div>

        <label class="mt-4 block">
          <span class="text-xs font-semibold uppercase tracking-widest text-henna-600">
            Style you&apos;re interested in
          </span>
          <select
            name="style"
            class="mt-1 w-full rounded-lg border border-henna-200 bg-cream px-3 py-2 text-sm focus:border-henna-500 focus:outline-none focus:ring-2 focus:ring-henna-200"
          >
            <option value="" selected disabled>Choose a category…</option>
            {categories.map((c) => <option value={c.title}>{c.title}</option>)}
            <option value="Not sure">Not sure yet</option>
          </select>
        </label>

        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-henna-600">Event date</span>
            <input
              name="date"
              type="date"
              class="mt-1 w-full rounded-lg border border-henna-200 bg-cream px-3 py-2 text-sm focus:border-henna-500 focus:outline-none focus:ring-2 focus:ring-henna-200"
            />
          </label>
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-henna-600">Placement</span>
            <input
              name="placement"
              placeholder="e.g. forearm, full hand"
              class="mt-1 w-full rounded-lg border border-henna-200 bg-cream px-3 py-2 text-sm focus:border-henna-500 focus:outline-none focus:ring-2 focus:ring-henna-200"
            />
          </label>
        </div>

        <label class="mt-4 block">
          <span class="text-xs font-semibold uppercase tracking-widest text-henna-600">
            Tell me about your design
          </span>
          <textarea
            name="message"
            rows="5"
            required
            class="mt-1 w-full rounded-lg border border-henna-200 bg-cream px-3 py-2 text-sm focus:border-henna-500 focus:outline-none focus:ring-2 focus:ring-henna-200"
            placeholder="Occasion, size, inspiration, references…"
          ></textarea>
        </label>

        <button type="submit" class="btn-primary mt-6 w-full">Send via WhatsApp</button>
        <p class="mt-3 text-center text-xs text-ink/50">
          Submitting opens WhatsApp with your details pre-filled — just press send.
          Prefer email? Write directly to{' '}
          <a
            href={`mailto:${site.contact.email}`}
            class="font-semibold text-henna-600 hover:text-henna-700"
          >
            {site.contact.email}
          </a>.
        </p>
      </form>
    </div>

    <div class="container-prose mt-16">
      <p class="text-center text-sm text-ink/60">
        Not sure which style fits?{' '}
        <a href="/#categories" class="font-semibold text-henna-600 hover:text-henna-700">
          Browse all categories →
        </a>
      </p>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name      = data.get('name')      || '—';
    const email     = data.get('email')     || '—';
    const style     = data.get('style')     || '—';
    const date      = data.get('date')      || '—';
    const placement = data.get('placement') || '—';
    const message   = data.get('message')   || '—';

    const text = [
      '🌿 *New Booking Request*',
      '',
      `*Name:* ${name}`,
      `*Email:* ${email}`,
      `*Style:* ${style}`,
      `*Date:* ${date}`,
      `*Placement:* ${placement}`,
      '',
      `*Message:*`,
      message,
    ].join('\n');

    const waUrl = `https://wa.me/355688178796?text=${encodeURIComponent(text)}`;
    window.open(waUrl, '_blank');
  });
</script>
