---
import Layout from '../../layouts/Layout.astro';
import PriceList from '../../components/PriceList.astro';
import PriceChart from '../../components/PriceChart.astro';
import DesignGallery from '../../components/DesignGallery.astro';
import { categories } from '../../lib/categories';
import { site } from '../../lib/site';

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const others = categories.filter((c) => c.slug !== category.slug);

const pageTitle = `${category.title} — ${site.name}`;
const pageDescription = category.description;
const shareImage = category.heroImage ?? category.image ?? '/images/logo.svg';
---

<Layout title={pageTitle} description={pageDescription} image={shareImage}>
  <section class={`relative overflow-hidden bg-gradient-to-br ${category.accent}`}>
    {
      (category.heroImage || category.image) && (
        <>
          <img
            src={category.heroImage ?? category.image}
            alt=""
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/50 to-black/40"></div>
        </>
      )
    }
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.12),transparent_60%)]"></div>
    <div class="container-prose relative py-20 sm:py-28">
      <a
        href="/#categories"
        class="inline-flex items-center gap-2 text-sm font-medium text-cream/90 hover:text-cream"
      >
        <span aria-hidden="true">←</span> All categories
      </a>
      <h1 class="mt-6 text-5xl font-display text-cream drop-shadow-lg sm:text-6xl">
        {category.title}
      </h1>
      <p class="mt-3 max-w-xl text-lg italic text-cream/90 drop-shadow">
        {category.tagline}
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-prose grid gap-12 lg:grid-cols-[1.3fr_1fr]">
      <div>
        <span class="eyebrow">About this style</span>
        <h2 class="mt-3 text-3xl font-display text-henna-700">
          {category.description}
        </h2>
        <p class="mt-4 text-ink/70">{category.longDescription}</p>

        <div class="mt-10">
          <span class="eyebrow">Gallery</span>
          <h3 class="mt-2 text-2xl font-display text-henna-700">Designs</h3>
          <div class="mt-4">
            <DesignGallery
              images={category.gallery}
              accent={category.accent}
              title={category.title}
            />
          </div>
        </div>
      </div>

      <aside class="lg:sticky lg:top-24 lg:self-start">
        <span class="eyebrow">Pricing</span>
        <h3 class="mt-2 text-2xl font-display text-henna-700">
          From {category.startingAt}
        </h3>
        <p class="mt-2 text-sm text-ink/60">
          Final price depends on size, detail and placement. Custom quotes on request.
        </p>

        {
          category.priceChart && (
            <div class="mt-5">
              <PriceChart
                src={category.priceChart}
                title={category.title}
                accent={category.accent}
              />
            </div>
          )
        }

        <div class="mt-5">
          <PriceList items={category.priceList} />
        </div>
        <a href="/contact" class="btn-primary mt-6 w-full">
          Book {category.title.toLowerCase()}
        </a>
      </aside>
    </div>
  </section>

  <section class="border-t border-henna-100 bg-henna-50/40 py-16">
    <div class="container-prose">
      <div class="flex items-end justify-between">
        <h2 class="text-2xl font-display text-henna-700 sm:text-3xl">
          Other styles you might love
        </h2>
        <a
          href="/#categories"
          class="text-sm font-semibold text-henna-600 hover:text-henna-700"
        >
          View all →
        </a>
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          others.map((c) => (
            <a
              href={`/categories/${c.slug}`}
              class={`group relative block aspect-[4/5] overflow-hidden rounded-2xl bg-gradient-to-br ${c.accent} text-cream shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg`}
            >
              {c.image ? (
                <>
                  <img
                    src={c.image}
                    alt={c.title}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-black/20" />
                </>
              ) : (
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
              )}

              <div class="relative flex h-full flex-col justify-between p-5">
                <p class="text-[10px] font-semibold uppercase tracking-[0.25em] text-cream/90 drop-shadow">
                  {c.tagline.split(' ').slice(0, 3).join(' ')}…
                </p>
                <div>
                  <p class="font-display text-2xl drop-shadow-md">{c.title}</p>
                  <p class="mt-1 text-sm text-cream/90 drop-shadow">
                    From {c.startingAt}
                  </p>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
