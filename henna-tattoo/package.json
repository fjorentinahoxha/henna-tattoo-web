{
  "name": "henna-tattoo-albania",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "images": "node scripts/optimize-images.mjs",
    "images:force": "node scripts/optimize-images.mjs --force",
    "images:dry": "node scripts/optimize-images.mjs --dry",
    "favicons": "node scripts/generate-favicons.mjs",
    "posters": "node scripts/fetch-event-posters.mjs",
    "posters:force": "node scripts/fetch-event-posters.mjs --force",
    "prebuild": "node scripts/optimize-images.mjs && node scripts/generate-favicons.mjs",
    "build": "astro build",
    "postbuild": "node -e \"const fs=require('fs');if(fs.existsSync('dist/_originals')){console.error('FATAL: dist/_originals exists — source photos must never be deployed.');process.exit(1)};console.log('✓ dist clean of _originals');\"",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.3.0",
    "konva": "^10.3.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^22",
    "sharp": "^0.32.6"
  }
}
